# LiteLLM proxy environment variables.
# Copy to litellm/.env (gitignored) and fill in values for this deployment.
# This file is sourced by litellm/start_proxy.sh before the proxy starts.
#
# Hardware swap (e.g. moving Higgs Audio to a new GPU node):
#   1. Update HIGGS_AUDIO_HOST below
#   2. bash litellm/stop_proxy.sh && bash litellm/start_proxy.sh
#   Done — static_models.yaml picks up the new IP on next proxy start.

# ── Audio model hosts ────────────────────────────────────────────────────────
# IP and port of the node running Higgs Audio TTS V3.
# Install with: bash scripts/install_higgs_audio.sh
HIGGS_AUDIO_HOST=http://10.2.35.20:8881

# Uncomment to enable Whisper STT routing through the proxy (if running as server)
# WHISPER_STT_HOST=http://10.2.35.20:8882
